# --- Secrets (never commit) ---
.env
.env.*
!.env.example
backend/.env
frontend/.env
frontend/.env.local
frontend/.env*.local
!.env.local.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/.venv/
venv/
.venv/
env/
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# --- Node / Next.js ---
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
.npm
*.tsbuildinfo
next-env.d.ts

# --- Harness run artifacts (local only) ---
workspace/*/
!workspace/.gitkeep

# --- Generated apps inside workspace (npm, vercel, next) ---
**/generated/node_modules/
**/generated/.next/
**/generated/.vercel/
**/generated/dist/
**/generated/build/

# --- OS / IDE ---
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# --- Logs & temp ---

backend/workspace/
**/_uploads/
*.tmp
*.temp
.cache/

# --- Vercel / deploy ---
.vercel/

