# Harness LLM providers (at least one required). Frontend Environment page can use these
# via "Backend .env" mode without pasting keys in the browser.
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEFAULT_PROVIDER=groq
# Run: python scripts/check_models.py — auto-picks best free models
# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=deepseek/deepseek-chat:free
# GEMINI_MODEL=gemini-2.0-flash
DATABASE_URL=postgresql://user:pass@host/db
GITHUB_TOKEN=
VERCEL_TOKEN=
# Team slug (required for non-interactive deploy). Find in Vercel dashboard URL or deploy error.
VERCEL_SCOPE=anshumans-projects-671c73a5
CORS_ORIGINS=http://localhost:3000
